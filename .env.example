# Neo4j connection (used by app, API routes, seed/import scripts)
# Local development only. Do not reuse these values in shared or production environments.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=opentalent-local-dev
NEO4J_DATABASE=neo4j

# Internal auth mode
# - development-bypass: local development convenience
# - proxy-header: trust identity headers injected by the internal VPN / reverse proxy / SSO layer
AUTH_MODE=development-bypass
AUTH_PROXY_EMAIL_HEADER=x-opentalent-user-email
AUTH_PROXY_NAME_HEADER=x-opentalent-user-name
AUTH_PROXY_ROLE_HEADER=x-opentalent-user-role
AUTH_DEV_USER_EMAIL=local.admin@airnav.co.id
AUTH_DEV_USER_NAME=Local Admin
AUTH_DEV_USER_ROLE=admin

# Optional assistant provider configuration
# Prefer privacy-safe providers in internal deployment environments.
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=
# OPENROUTER_API_KEY=
